# Environment variables (copy this to .env.local and fill in your values)

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (GPT fallback)
OPENAI_API_KEY=sk-...

# GitHub
GITHUB_APP_ID=your-github-app-id
GITHUB_PRIVATE_KEY=your-github-private-key
GITHUB_WEBHOOK_SECRET=your-webhook-secret
GITHUB_CLIENT_ID=your-client-id
GITHUB_CLIENT_SECRET=your-client-secret

# GitHub Personal Access Token (read-only repo scope)
# Para hidratar el diff de commits via API. Crear en:
#   https://github.com/settings/tokens?type=beta  (fine-grained, recomendado)
#   o https://github.com/settings/tokens/new?scopes=repo  (classic)
# Scope necesario: "Contents: Read" (fine-grained) o "repo" (classic, read-only)
GITHUB_TOKEN=ghp_...

# GitLab
GITLAB_APP_ID=your-gitlab-app-id
GITLAB_SECRET=your-gitlab-secret
GITLAB_WEBHOOK_SECRET=your-webhook-secret

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# LangChain
LANGCHAIN_API_KEY=your-langchain-api-key
LANGCHAIN_TRACING_V2=true
LANGCHAIN_PROJECT=docuai-agent

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
